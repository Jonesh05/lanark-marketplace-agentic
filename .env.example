# LANARK environment template. Copy to .env.local (Next.js) and .env (scripts).
# Do not commit real secrets.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct (non-pooling) Postgres URL used by scripts/run_migration.js
POSTGRES_URL_NON_POOLING=

# --- Reown AppKit (wallet + social/email login) ---
# Required for social/email login to authenticate. Without it AppKit runs in a
# degraded "missing-project-id" mode and email login will not complete.
NEXT_PUBLIC_PROJECT_ID=

# --- Azure OpenAI (agent) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# --- Settlement chain (parameterized per environment) ---
# Active settlement chain id. 42220 = Celo mainnet, 11142220 = Celo Sepolia
# testnet (Alfajores is deprecated; Celo Sepolia is the current testnet).
LANARK_CHAIN_ID=11142220
# RPC override. Defaults to forno mainnet/testnet based on LANARK_CHAIN_ID.
CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
# Settlement token (cUSD-class, 18 decimals). On testnet, the deployed test
# asset (USDm / Mento Dollar) or a MockERC20 deployed for testnet. On mainnet,
# leave empty to use canonical cUSD.
LANARK_SETTLEMENT_TOKEN=
# Escrow factory address (EIP-1167). When set, settlement runs on-chain;
# when empty, the honest off-chain provider is used (orders park as
# awaiting_settlement, never faked as settled).
LANARK_ESCROW_FACTORY=
# Protocol fee in basis points (100 = 1%).
LANARK_FEE_BPS=100

# --- Foundry deploy (scripts only; never expose client-side) ---
# Deployer private key for `forge script` on Celo Sepolia.
PRIVATE_KEY=
# Constructor/initialize params for the escrow factory deploy.
LANARK_TREASURY=
LANARK_ARBITER=
LANARK_FACTORY_OWNER=
CELOSCAN_API_KEY=
